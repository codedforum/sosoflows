
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /sosoflows/
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^.*$ index.html [L]
</IfModule>

<IfModule mod_headers.c>

  Header set Cache-Control "public, max-age=300"
</IfModule>

<Files ".api-key">
  Order allow,deny
  Deny from all
</Files>
<Files ".groq-key">
  Order allow,deny
  Deny from all
</Files>
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>
